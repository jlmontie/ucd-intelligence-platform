# Copy this file to .env and fill in values. Never commit .env.

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: Cloud SQL Auth Proxy must be running (see infra/setup.sh)
DATABASE_URL=postgresql://ucd_user:CHANGE_ME@localhost:5432/ucd_db

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT=uc-and-d
GCS_BUCKET=uc-and-d-assets
# Leave blank to use Application Default Credentials (gcloud auth login)
GOOGLE_APPLICATION_CREDENTIALS=

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Uncomment if using OpenAI or Gemini as fallback
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ── API (production only) ────────────────────────────────────────────────────
# SECRET_KEY is used to sign JWT tokens for the embedded widget
SECRET_KEY=CHANGE_ME_32_random_bytes
