# Copy this file to .env and fill in values. Never commit .env.

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: Cloud SQL Auth Proxy must be running (see infra/setup.sh)
DATABASE_URL=postgresql://ucd_user:CHANGE_ME@localhost:5432/ucd_db

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT=uc-and-d
GCS_BUCKET=uc-and-d-assets
# Leave blank to use Application Default Credentials (gcloud auth login)
GOOGLE_APPLICATION_CREDENTIALS=

# ── Vertex AI (LLM) ──────────────────────────────────────────────────────────
# Production: the Cloud Run service account has roles/aiplatform.user — no key needed.
# Local dev: run `gcloud auth application-default login` and set these two vars.
VERTEXAI_PROJECT=uc-and-d
VERTEXAI_LOCATION=us-east5

# Optional — override the default model per environment (core/llm.py reads this).
# Leave blank to use vertex_ai/gemini-2.5-flash.
LITELLM_MODEL=

# ── Langfuse (LLM tracing + cost attribution; plan §3.3) ─────────────────────
# Sign up at https://cloud.langfuse.com (free tier = 10K observations/month,
# enough for one full-corpus run). Project Settings → API Keys → Create.
# Leave blank to disable tracing — core/llm.py only enables the callback
# when both keys are present.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com

# ── API (production only) ────────────────────────────────────────────────────
# SECRET_KEY is used to sign JWT tokens for the embedded widget
SECRET_KEY=CHANGE_ME_32_random_bytes
