# Copy to terraform.tfvars and fill in secrets. Never commit terraform.tfvars.

project         = "uc-and-d"
region          = "us-central1"
vertex_location = "us-east5"
db_tier         = "db-g1-small"

secret_key = ""   # generate: openssl rand -base64 32

